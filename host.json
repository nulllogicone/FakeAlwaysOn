{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "samplingPercentage": 100,
        "excludedTypes": "Request",
        "excludedPaths": "health_check_function"
      }
    }
  },
  "functionTimeout": "00:05:00",
  "extensions": {
    "durableTask": {
      "tracing": {
        "traceInputsAndOutputs": true
      }
    },
    "http": {
      "routePrefix": "api"
    }
  }
}
